{
  "name": "claude-coverwise",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "description": "Claude Code plugin: pairwise / t-wise combinatorial coverage for AI-written tests, backed by the coverwise WASM engine",
  "license": "Apache-2.0",
  "author": "libraz <libraz@libraz.net>",
  "bin": "./mcp/cli.mjs",
  "homepage": "https://github.com/libraz/claude-coverwise",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/libraz/claude-coverwise.git"
  },
  "bugs": {
    "url": "https://github.com/libraz/claude-coverwise/issues"
  },
  "keywords": [
    "claude-code",
    "mcp",
    "pairwise",
    "t-wise",
    "combinatorial",
    "testing",
    "coverage"
  ],
  "scripts": {
    "start": "node mcp/server.mjs",
    "init": "node mcp/cli.mjs init",
    "uninstall": "node mcp/cli.mjs uninstall",
    "lint": "biome check mcp/ scripts/ tests/",
    "lint:fix": "biome check --write mcp/ scripts/ tests/",
    "format": "biome format --write mcp/ scripts/ tests/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@libraz/coverwise": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "volta": {
    "node": "22.21.1",
    "yarn": "4.12.0"
  }
}
